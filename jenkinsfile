pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/your-username/your-repo.git'
            }
        }

        stage('Build') {
            steps {
                sh 'echo "Building project"'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar server') {
                    sh 'sonar-scanner'
                }
            }
        }

    }
}
